# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# WAHA (WhatsApp HTTP API)
WAHA_URL=https://sua-instancia-waha.com
WAHA_API_KEY=sua-chave-waha
WAHA_SESSION=default

# PsiPlanner (Next.js no Vercel)
PSICO_API_URL=https://psiplanner.vercel.app
AGENTE_API_KEY=mesma-chave-do-vercel-env-AGENTE_API_KEY

# Psicólogo
PSICOLOGO_ID=uuid-do-psicologo
PSICOLOGA_PHONE=5521999999999

# Configurações
BUFFER_DELAY=3
ENV=production

# Segurança — Telegram
TELEGRAM_TOKEN=token-do-botfather
TELEGRAM_WEBHOOK_SECRET=string-aleatoria-32chars
ADMIN_KEY=string-aleatoria-32chars-para-setup-telegram
