    {
      "parameters": {
        "jsCode": "// Humanizar resposta: divide em partes naturais para simular digitação humana\nconst resposta = $input.first().json.output;\n\n// Divide em frases/parágrafos\nconst partes = resposta\n  .split(/(?<=[.!?])\\s+/)\n  .reduce((acc, frase) => {\n    if (acc.length === 0) {\n      acc.push(frase);\n    } else {\n      const ultimo = acc[acc.length - 1];\n      if (ultimo.length + frase.length < 200) {\n        acc[acc.length - 1] = ultimo + ' ' + frase;\n      } else {\n        acc.push(frase);\n      }\n    }\n    return acc;\n  }, []);\n\n// Adiciona delay proporcional ao tamanho de cada parte (simula digitação)\nconst phone = $('Dados Lead').first().json.phone;\nconst instanceId = $('Dados Lead').first().json.instanceId;\n\nreturn partes.map((texto, i) => ({\n  json: {\n    phone,\n    instanceId,\n    texto: texto.trim(),\n    delay: Math.min(1000 + texto.length * 30, 5000), // ~30ms por char, max 5s\n    ordem: i\n  }\n}));"
      },
      "id": "29",
      "name": "Humanizar Resposta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3820, 300]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "30",
      "name": "Loop por Partes",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [4040, 300]
    },
